  "mainHtml": "<!-- Hero Section -->\n <section class=\"hero hero--inner\">\n <div class=\"hero__background\">\n <img src=\"/assets/images/hero/healthcare-hero.webp\" alt=\"healthcare facility cleaning services in Hudson, Massachusetts\" loading=\"eager\" fetchpriority=\"high\" width=\"1200\" height=\"600\">\n <div class=\"hero__overlay hero__overlay--gradient\"></div>\n </div>\n <div class=\"container\">\n <div class=\"hero__content hero__content--center\">\n <div class=\"hero__badge\">\n <svg class=\"hero__badge-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z\"/></svg>\n <span>Serving Hudson, Middlesex County</span>\n </div>\n <h1 class=\"hero__title\">Healthcare Cleaning Services in <span>Hudson, MA</span></h1>\n <p class=\"hero__subtitle\">Trusted by medical practices in Hudson for over 22 years. Licensed, insured, and committed to delivering precision sanitation for medical offices and clinics.</p>\n <div class=\"hero__ctas\">\n <a href=\"/contact\" class=\"btn btn--primary btn--lg btn--pulse\">Schedule Facility Assessment</a>\n <a href=\"tel:+19783078107\" class=\"btn btn--outline-light btn--lg\">\n <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z\"/></svg>\n Call (978) 307-8107\n </a>\n </div>\n </div>\n </div>\n </section>\n\n <!-- Intro Section -->\n <section class=\"section\">\n <div class=\"container\">\n <div class=\"video-text-section\">\n <div class=\"video-text-section__content\">\n <span class=\"video-text-section__badge\">Hudson, MA</span>\n <h2 class=\"video-text-section__title\">Your Trusted Healthcare Partner in Hudson</h2>\n <p class=\"video-text-section__text\">Located in Middlesex County, Hudson is a vibrant community that deserves clean, healthy spaces. Whether you need medical office cleaning, infection control, or compliance-driven sanitation for your healthcare facility on Main Street, Dory's Cleaning Services delivers exceptional results every time.</p>\n <ul class=\"video-text-section__list\">\n <li>Serving Hudson healthcare facilities for over 22 years</li>\n <li>Fully insured in Massachusetts ($2M coverage)</li>\n <li>Flexible scheduling including early mornings and evenings</li>\n <li>Eco-friendly cleaning products available</li>\n </ul>\n <a href=\"/contact\" class=\"btn btn--primary btn--lg\">Request a Free Facility Assessment</a>\n </div>\n <div class=\"video-text-section__video\">\n <img src=\"../assets/images/services/specialty-clinic.webp\" alt=\"Professional cleaning team at work in Hudson, MA\" style=\"width: 100%; height: auto; border-radius: 16px; box-shadow: 0 20px 40px rgba(0,0,0,0.12);\" width=\"600\" height=\"400\">\n </div>\n </div>\n </div>\n </section>\n\n <!-- Services Section -->\n <section class=\"section section--gradient-blue\">\n <div class=\"container\">\n <div class=\"section__header section__header--center\">\n <span class=\"section__badge\">Our Services</span>\n <h2 class=\"section__title\">Healthcare Services Available in Hudson</h2>\n <p class=\"section__description\">Comprehensive healthcare solutions for Hudson medical offices, clinics, and facilities.</p>\n </div>\n\n <div class=\"services-grid--5items\">\n <article class=\"service-card--premium\">\n <div class=\"service-card__image\">\n <img src=\"../assets/images/services/medical-office-new.webp\" alt=\"Medical Offices in Hudson, MA\" loading=\"lazy\" decoding=\"async\" width=\"600\" height=\"400\">\n </div>\n <div class=\"service-card__body\">\n <h3 class=\"service-card__title\">Medical Office Cleaning</h3>\n <p class=\"service-card__text\">Comprehensive healthcare for Hudson medical offices, physician practices, and healthcare administrative spaces.</p>\n <a href=\"/services/medical-office-cleaning/hudson-ma\" class=\"service-card__link\">\n Learn More\n <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z\"/></svg>\n </a>\n </div>\n </article>\n\n <article class=\"service-card--premium\">\n <div class=\"service-card__image\">\n <img src=\"../assets/images/services/specialty-clinic.webp\" alt=\"Specialty Clinic Cleaning in Hudson, MA\" loading=\"lazy\" decoding=\"async\" width=\"600\" height=\"400\">\n </div>\n <div class=\"service-card__body\">\n <h3 class=\"service-card__title\">Specialty Clinics</h3>\n <p class=\"service-card__text\">Specialized sanitation for Hudson outpatient clinics, urgent care centers, and ambulatory surgical centers.</p>\n <a href=\"/services/specialty-clinics/hudson-ma\" class=\"service-card__link\">\n Learn More\n <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z\"/></svg>\n </a>\n </div>\n </article>\n\n <article class=\"service-card--premium\">\n <div class=\"service-card__image\">\n <img src=\"../assets/images/services/rehab-nursing.webp\" alt=\"Rehabilitation Facility Environmental Cleaning in Hudson, MA\" loading=\"lazy\" decoding=\"async\" width=\"600\" height=\"400\">\n </div>\n <div class=\"service-card__body\">\n <h3 class=\"service-card__title\">Rehabilitation & Nursing</h3>\n <p class=\"service-card__text\">Targeted high-touch surface disinfection in Hudson using hospital-grade EPA-registered products and CDC-aligned protocols.</p>\n <a href=\"/services/rehab-nursing/hudson-ma\" class=\"service-card__link\">\n Learn More\n <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z\"/></svg>\n </a>\n </div>\n </article>\n\n <article class=\"service-card--premium\">\n <div class=\"service-card__image\">\n <img s