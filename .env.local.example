# Copy to .env.local (gitignored) for local dev.
# For production, set these in Vercel → Settings → Environment Variables.

# GHL Private Integration Token — server-side only. Never expose to browser.
# Rotate via GHL → Settings → Private Integrations after any leakage.
GHL_PIT=pit-REPLACE-ME-WITH-FRESH-TOKEN

# GHL Location ID — safe to expose (it's already in the iframe URL).
GHL_LOCATION_ID=BQd0L6DeFvVbjKS8VYZ9
